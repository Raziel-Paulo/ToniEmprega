@using ToniEmprega.Models
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
<!doctype html>
<html lang="pt-PT">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title - ToniEmprega</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <script src="~/js/site.js" defer></script>
</head>
<body class="app-root">
    <header class="app-header" role="banner">
        <div class="brand">ToniEmprega</div>
        <div class="search" role="search">
            <input aria-label="Pesquisar ofertas e empresas" placeholder="Pesquisar ofertas, empresas..." />
        </div>
        <div class="header-actions">
            <button class="icon-btn" aria-label="Notificações">🔔</button>
            <div class="avatar" aria-haspopup="true" aria-expanded="false">
                <button class="avatar-btn" aria-label="Conta do utilizador">@HttpContextAccessor.HttpContext?.User?.Identity?.Name</button>
            </div>
        </div>
    </header>


    <div class="app-body">
        <aside class="sidebar" role="navigation" aria-label="Menu principal">
            <nav>
                <ul>
                    <li><a href="/">Home</a></li>
                    <li><a href="/offers">Ofertas</a></li>
                    <li><a href="/applications">Candidaturas</a></li>
                    <li><a href="/messages">Mensagens</a></li>
                    <li><a href="/documents">Documentos</a></li>
                </ul>
            </nav>
        </aside>


        <main class="main-content" role="main">
            @RenderBody()
        </main>


        <aside class="right-rail" role="complementary">
            <section>
                <h3>Ajuda</h3>
                <p>Precisa de ajuda? Contacte a equipa.</p>
            </section>
        </aside>
    </div>


    <footer class="app-footer" role="contentinfo">
        <small>© ToniEmprega — Versão 1.0</small>
    </footer>
</body>
</html>